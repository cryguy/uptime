# Server
PORT=3000

# Admin credentials.
# Generate the hash:  bun run hash <password>
# The script outputs an escaped line ready to paste; '$' chars in the
# argon2 hash are backslash-escaped because Bun's dotenv expands '$VAR'
# references even inside single-quoted values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# 32-byte hex string. Signs session cookies.
# Generate with:  bun run keygen
SESSION_SECRET=

# 32-byte hex string. Encrypts monitor configs at rest (incl. SSH keys, tokens).
# WARNING: losing this means all monitor configurations become unreadable.
# Generate with:  bun run keygen
ENCRYPTION_KEY=

# SQLite file path
DB_PATH=./data/uptime.db

# Auto-acknowledge open incidents older than this many minutes (0 = off).
# Auto-acked incidents stop showing in the banner / nav badge but stay
# visible in /incidents until the underlying monitor recovers.
INCIDENT_AUTO_ACK_MINUTES=0
